# ─────────────────────────────────────────────
# Termimal backend — environment variables
#
# Copy to .env and fill in real keys:
#     cp .env.example .env
#
# .env is gitignored — never commit real keys.
# Rotate any key that has been pasted in chat, screenshots, or
# committed accidentally.
# ─────────────────────────────────────────────

# ── Macro data ─────────────────────────────
# FRED — free, register at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Financial Modeling Prep — free tier 250 req/day
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# ── Optional alternatives ─────────────────
# Polygon.io — for licensed real-time equity / options / forex
# Production-grade replacement for yfinance. https://polygon.io
POLYGON_API_KEY=

# Alpha Vantage — free, 5 req/min, 500/day. Commercial-licensed.
ALPHA_VANTAGE_API_KEY=

# Twelve Data — alternative OHLCV
TWELVE_DATA_API_KEY=

# Quandl / Nasdaq Data Link
QUANDL_API_KEY=

# ── Auth / access ─────────────────────────
# Legacy shared token used by AccessGate as a dev fallback. Once Supabase
# JWT verification is configured, real users authenticate via
# `Authorization: Bearer <jwt>`; this token only acts as a dev / health-check
# fallback. Pick a long random value (32+ chars).
ACCESS_TOKEN=change-me-to-a-32-char-random-string

# ── Supabase ──────────────────────────────
# Public project URL (also used in the frontend as VITE_SUPABASE_URL).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# JWT signing secret. Find it in Supabase dashboard at
#   Project Settings → API → JWT Settings → JWT Secret
# Required to verify Supabase access tokens server-side. Without it, the
# backend falls back to the legacy ACCESS_TOKEN.
SUPABASE_JWT_SECRET=

# Service-role key — bypasses Row-Level Security. ONLY for server-side admin
# operations (account deletion, webhook writes). Never expose to the browser
# bundle. Rotate on suspicion of leak.
SUPABASE_SERVICE_ROLE_KEY=

# ── CORS / hosting ────────────────────────
# Comma-separated list of origins allowed to call the API.
# Lock this down in production — never use *.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Environment ───────────────────────────
# development | production. In production, ACCESS_TOKEN must be set.
TERMIMAL_ENV=development

# ── Notes ─────────────────────────────────
# • yfinance does not require a key but is not licensed for
#   commercial / paid redistribution. Migrate to Polygon /
#   Alpha Vantage / Tradier before charging users.
# • Never log full keys. Mask the middle 60% of any key in logs.

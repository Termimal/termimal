# Frontend env — copy to .env.local and fill in.
# .env.local is gitignored.
#
# These values are read by vite.config.ts when the dev server starts.

# ── Supabase Auth (real per-user auth) ──────────────────────
# Both values are public client-side keys — safe to ship in the browser bundle.
# Find them in Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ── Backend access (legacy shared token, retained as dev fallback) ──
# Must match backend ACCESS_TOKEN if it is set. After Supabase auth lands,
# every authenticated request is sent with the user's JWT in the Authorization
# header instead of this token; this fallback only matters for unauthenticated
# health-check style requests.
VITE_ACCESS_TOKEN=

# Backend origin for the dev proxy. Default: http://127.0.0.1:8000
VITE_BACKEND_URL=

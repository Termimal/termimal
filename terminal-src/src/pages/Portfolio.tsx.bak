// pages/Portfolio.tsx — TradingView-style portfolio
import { useState, useMemo, useEffect, useRef } from 'react'
import { useNavigate } from 'react-router-dom'
import { useStore } from '@/store/useStore'
import { fetchPriceHistory } from '@/api/client'
import { TvCandleChart } from '@/components/charts/TvCandleChart'

interface Position { id: string; symbol: string; shares: number; entry: number; date: string }

const STORAGE_KEY = 'ft-portfolio'
function load(): Position[] {
  try {
    const raw = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]')
    if (!Array.isArray(raw)) return []
    // Migrate: ensure every position has an id
    let needsSave = false
    const migrated = raw.map((p: any, i: number) => {
      if (!p.id) { needsSave = true; p.id = `migrated-${Date.now()}-${i}` }
      if (!p.symbol && p.sym) { needsSave = true; p.symbol = p.sym } // old format compat
      return p as Position
    }).filter((p: Position) => p.symbol && p.shares > 0 && p.entry > 0)
    if (needsSave) localStorage.setItem(STORAGE_KEY, JSON.stringify(migrated))
    return migrated
  } catch { return [] }
}
function save(p: Position[]) { localStorage.setItem(STORAGE_KEY, JSON.stringify(p)) }

const SECTORS: Record<string, string> = {
  AAPL:'Tech',MSFT:'Tech',NVDA:'Tech',GOOGL:'Tech',META:'Tech',AMZN:'Tech',AMD:'Tech',PLTR:'Tech',
  TSLA:'Auto',F:'Auto',GM:'Auto',CAT:'Industrial',
  JPM:'Finance',BAC:'Finance',GS:'Finance',
  XOM:'Energy',CVX:'Energy',
  JNJ:'Health',PFE:'Health',UNH:'Health',
  WMT:'Consumer',KO:'Consumer',PG:'Consumer',
}
const SCOL: Record<string, string> = { Tech:'#388bfd',Finance:'#d29922',Energy:'#f85149',Auto:'#3fb950',Health:'#7c4dff',Consumer:'#00bcd4',Industrial:'#8bc34a',Other:'#8b949e' }

function PositionSizer({ portfolioValue }: { portfolioValue: number }) {
  const [riskPct, setRiskPct] = useState('1')
  const [entryPrice, setEntryPrice] = useState('')
  const [stopPrice, setStopPrice] = useState('')
  const pf = portfolioValue
  const rp = +riskPct, ep = +entryPrice, sp = +stopPrice
  const valid = pf > 0 && rp > 0 && ep > 0 && sp > 0 && ep !== sp
  const riskPerShare = valid ? Math.abs(ep - sp) : 0
  const maxRisk = pf * (rp / 100)
  const shares = valid ? Math.floor(maxRisk / riskPerShare) : 0
  const posSize = shares * ep
  const posPct = pf > 0 ? (posSize / pf) * 100 : 0
  const inpS = { background: '#0e1117', border: '1px solid #21262d', color: '#c9d1d9', fontSize: 12, padding: '6px 10px', borderRadius: 2, outline: 'none' } as const
  return (
    <div>
      <div style={{ display: 'flex', gap: 10, marginBottom: 10, flexWrap: 'wrap' }}>
        <div><div style={{ fontSize: 10, color: '#8b949e', marginBottom: 3 }}>Portfolio: ${pf.toLocaleString(undefined,{maximumFractionDigits:0})}</div></div>
        <div><div style={{ fontSize: 10, color: '#8b949e', marginBottom: 3 }}>Risk %</div><input value={riskPct} onChange={e => setRiskPct(e.target.value)} type="number" step="0.1" style={{ ...inpS, width: 70 }} /></div>
        <div><div style={{ fontSize: 10, color: '#8b949e', marginBottom: 3 }}>Entry</div><input value={entryPrice} onChange={e => setEntryPrice(e.target.value)} type="number" step="0.01" placeholder="150.00" style={{ ...inpS, width: 90 }} /></div>
        <div><div style={{ fontSize: 10, color: '#8b949e', marginBottom: 3 }}>Stop Loss</div><input value={stopPrice} onChange={e => setStopPrice(e.target.value)} type="number" step="0.01" placeholder="145.00" style={{ ...inpS, width: 90 }} /></div>
      </div>
      {valid && (
        <div style={{ display: 'flex', gap: 12, fontSize: 11 }}>
          <span style={{ color: '#388bfd' }}>Shares: <b>{shares}</b></span>
          <span style={{ color: '#c9d1d9' }}>Size: <b>${posSize.toLocaleString(undefined,{maximumFractionDigits:0})}</b> ({posPct.toFixed(1)}%)</span>
          <span style={{ color: '#f85149' }}>Max Risk: <b>${maxRisk.toFixed(0)}</b></span>
          <span style={{ color: '#3fb950' }}>R:R → 1R: ${(ep + riskPerShare).toFixed(2)} · 2R: ${(ep + riskPerShare * 2).toFixed(2)} · 3R: ${(ep + riskPerShare * 3).toFixed(2)}</span>
        </div>
      )}
    </div>
  )
}

export function Portfolio() {
  const navigate = useNavigate()
  const prices = useStore(s => s.prices)
  const [positions, setPositions] = useState<Position[]>(load)
  const [showAdd, setShowAdd] = useState(false)
  const [sym, setSym] = useState('')
  const [shares, setShares] = useState('')
  const [entry, setEntry] = useState('')
  const [date, setDate] = useState(new Date().toISOString().slice(0, 10))
  const [distTab, setDistTab] = useState<'sectors' | 'assets'>('sectors')
  const [chartPeriod, setChartPeriod] = useState<string>('3mo')
  const [chartData, setChartData] = useState<{ dates: string[]; close: number[]; open: number[]; high: number[]; low: number[]; volume: number[] } | null>(null)
  const [chartLoading, setChartLoading] = useState(false)

  // Fetch portfolio value chart
  useEffect(() => {
    if (positions.length === 0) { setChartData(null); return }
    let cancelled = false
    setChartLoading(true)

    const syms = [...new Set(positions.map(p => p.symbol))]
    Promise.all(syms.map(s => fetchPriceHistory(s, chartPeriod as any))).then(results => {
      if (cancelled) return

      // Build date → portfolio value map
      const dateMap: Record<string, number> = {}
      const sharesMap: Record<string, number> = {}
      positions.forEach(p => { sharesMap[p.symbol] = (sharesMap[p.symbol] ?? 0) + p.shares })

      results.forEach((hist, idx) => {
        if (!hist?.dates?.length) return
        const s = syms[idx]
        const sh = sharesMap[s] ?? 0
        hist.dates.forEach((d: string, i: number) => {
          const dateKey = d.slice(0, 10)
          dateMap[dateKey] = (dateMap[dateKey] ?? 0) + hist.close[i] * sh
        })
      })

      const sortedDates = Object.keys(dateMap).sort()
      if (sortedDates.length < 2) { setChartData(null); setChartLoading(false); return }

      // Fill missing dates (some symbols may not have data on all days)
      const closes = sortedDates.map(d => dateMap[d])
      const costBasis = positions.reduce((s, p) => s + p.entry * p.shares, 0)
      // Show as P/L line (value - cost) or absolute value
      const pnlLine = closes.map(v => +(v - costBasis).toFixed(2))

      setChartData({
        dates: sortedDates,
        open: pnlLine, high: pnlLine, low: pnlLine, close: pnlLine,
        volume: closes.map(() => 0),
      })
      setChartLoading(false)
    }).catch(() => setChartLoading(false))

    return () => { cancelled = true }
  }, [positions, chartPeriod, prices])

  const sv = (p: Position[]) => { setPositions(p); save(p) }
  const add = () => {
    if (!sym || !shares || !entry) return
    sv([...positions, { id: Date.now().toString(), symbol: sym.toUpperCase(), shares: +shares, entry: +entry, date }])
    setSym(''); setShares(''); setEntry(''); setShowAdd(false)
  }
  const remove = (id: string) => {
    const filtered = positions.filter(p => p.id !== id)
    // Fallback: if nothing was removed (id mismatch), try by index
    if (filtered.length === positions.length) {
      const idx = positions.findIndex(p => p.id === id)
      if (idx >= 0) { const copy = [...positions]; copy.splice(idx, 1); sv(copy); return }
      // Last resort: find by matching row data
      console.warn('Portfolio remove: id mismatch, trying symbol match')
    }
    sv(filtered)
  }
  const clearAll = () => { if (window.confirm('Remove ALL positions?')) sv([]) }

  const rows = useMemo(() => positions.map(p => {
    const live = prices[p.symbol]?.price ?? p.entry
    const pnl = (live - p.entry) * p.shares
    const pnlPct = ((live - p.entry) / p.entry) * 100
    const value = live * p.shares
    const cost = p.entry * p.shares
    const dayChg = prices[p.symbol]?.pct ?? 0
    const sector = SECTORS[p.symbol] ?? 'Other'
    return { ...p, live, pnl, pnlPct, value, cost, dayChg, sector }
  }), [positions, prices])

  const totalValue = rows.reduce((s, r) => s + r.value, 0)
  const totalCost = rows.reduce((s, r) => s + r.cost, 0)
  const totalPnl = totalValue - totalCost
  const totalPnlPct = totalCost > 0 ? (totalPnl / totalCost) * 100 : 0
  const dayPnl = rows.reduce((s, r) => s + (r.live * r.shares * r.dayChg / 100), 0)

  // Gainers / Losers
  const sorted = [...rows].sort((a, b) => b.dayChg - a.dayChg)
  const gainers = sorted.filter(r => r.dayChg > 0).slice(0, 5)
  const losers = sorted.filter(r => r.dayChg < 0).sort((a, b) => a.dayChg - b.dayChg).slice(0, 5)
  const maxAbsChg = Math.max(...sorted.map(r => Math.abs(r.dayChg)), 1)

  // Sectors
  const sectors = useMemo(() => {
    const m: Record<string, number> = {}
    rows.forEach(r => { m[r.sector] = (m[r.sector] ?? 0) + r.value })
    return Object.entries(m).sort((a, b) => b[1] - a[1]).map(([name, val]) => ({ name, val, pct: totalValue > 0 ? (val / totalValue) * 100 : 0 }))
  }, [rows, totalValue])

  // Donut SVG
  const DonutChart = () => {
    if (sectors.length === 0) return null
    const r = 70, cx = 90, cy = 90, sw = 18
    let cum = 0
    const circ = 2 * Math.PI * r
    return (
      <svg width={180} height={180} viewBox="0 0 180 180">
        {sectors.map(s => {
          const pct = s.pct / 100
          const offset = circ * cum
          const len = circ * pct
          cum += pct
          return <circle key={s.name} cx={cx} cy={cy} r={r} fill="none" stroke={SCOL[s.name] ?? '#8b949e'} strokeWidth={sw}
            strokeDasharray={`${len} ${circ - len}`} strokeDashoffset={-offset} transform={`rotate(-90 ${cx} ${cy})`} />
        })}
        <text x={cx} y={cy - 6} textAnchor="middle" fill="#c9d1d9" fontSize="20" fontWeight="600">{rows.length}</text>
        <text x={cx} y={cy + 12} textAnchor="middle" fill="#8b949e" fontSize="10">Holdings</text>
      </svg>
    )
  }

  const inp = { background: '#0e1117', border: '1px solid #21262d', color: '#c9d1d9', fontSize: 12, padding: '6px 10px', borderRadius: 2, outline: 'none' } as const
  const fmtUsd = (n: number) => (n >= 0 ? '' : '-') + '$' + Math.abs(n).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })
  const mono = "'SF Mono', Menlo, Consolas, monospace"

  const [addMode, setAddMode] = useState<'' | 'manual' | 'watchlist' | 'csv'>('')
  const watchlist = useStore(s => s.watchlist)
  const csvRef = useRef<HTMLInputElement>(null)

  const addFromWL = (s: string) => {
    const live = prices[s]?.price ?? 100
    sv([...positions, { id: Date.now().toString(), symbol: s, shares: 1, entry: live, date: new Date().toISOString().slice(0, 10) }])
  }

  const handleCSV = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0]
    if (!file) return
    const reader = new FileReader()
    reader.onload = (ev) => {
      const text = ev.target?.result as string
      const lines = text.split('\n').map(l => l.trim()).filter(Boolean)
      if (lines.length < 2) return
      // Auto-detect columns: look for symbol,shares,price,date headers
      const header = lines[0].toLowerCase().split(/[,;\t]/)
      const symIdx = header.findIndex(h => h.includes('symbol') || h.includes('ticker'))
      const sharesIdx = header.findIndex(h => h.includes('share') || h.includes('qty') || h.includes('quantity'))
      const priceIdx = header.findIndex(h => h.includes('price') || h.includes('cost') || h.includes('entry'))
      const dateIdx = header.findIndex(h => h.includes('date'))

      const newPos: Position[] = []
      for (let i = 1; i < lines.length; i++) {
        const cols = lines[i].split(/[,;\t]/)
        const sym = (cols[symIdx >= 0 ? symIdx : 0] ?? '').toUpperCase().trim()
        const sh = parseFloat(cols[sharesIdx >= 0 ? sharesIdx : 1] ?? '0')
        const pr = parseFloat(cols[priceIdx >= 0 ? priceIdx : 2] ?? '0')
        const dt = cols[dateIdx >= 0 ? dateIdx : 3]?.trim() || new Date().toISOString().slice(0, 10)
        if (sym && sh > 0 && pr > 0) {
          newPos.push({ id: Date.now().toString() + i, symbol: sym, shares: sh, entry: pr, date: dt })
        }
      }
      if (newPos.length > 0) sv([...positions, ...newPos])
      setAddMode(''); setShowAdd(false)
    }
    reader.readAsText(file)
    if (csvRef.current) csvRef.current.value = ''
  }

  return (
    <div style={{ padding: '16px 20px', minHeight: '100%' }}>

      {/* ══════ PORTFOLIO HUB — empty state ══════ */}
      {rows.length === 0 && !showAdd && (
        <div>
          <div style={{ fontSize: 15, fontWeight: 600, color: '#e6edf3', letterSpacing: '0.03em', marginBottom: 20 }}>PORTFOLIOS</div>
          <div style={{ textAlign: 'center', padding: '40px 20px', background: '#0b0e11', border: '1px solid #21262d' }}>
            <div style={{ fontSize: 14, color: '#c9d1d9', marginBottom: 6 }}>No holdings yet</div>
            <div style={{ fontSize: 11, color: '#8b949e', marginBottom: 24 }}>Create your portfolio to start tracking performance</div>
            {/* Three equal creation cards */}
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 12, maxWidth: 600, margin: '0 auto' }}>
              {[
                { mode: 'csv' as const, label: 'Upload CSV file', desc: 'Quickly transfer all transactions from a file', icon: (
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="#8b949e" strokeWidth="1.3"><path d="M11 14V4m0 0L7 8m4-4l4 4"/><path d="M3 14v4h16v-4"/></svg>
                )},
                { mode: 'manual' as const, label: 'Create manually', desc: 'Add only the transactions you want by hand', icon: (
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="#8b949e" strokeWidth="1.3"><line x1="11" y1="5" x2="11" y2="17"/><line x1="5" y1="11" x2="17" y2="11"/></svg>
                )},
                { mode: 'watchlist' as const, label: 'Add from watchlist', desc: 'Choose from saved watchlists and customize', icon: (
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="#8b949e" strokeWidth="1.3"><rect x="4" y="4" width="14" height="14" rx="1"/><line x1="7" y1="8" x2="15" y2="8"/><line x1="7" y1="11" x2="13" y2="11"/><line x1="7" y1="14" x2="11" y2="14"/></svg>
                )},
              ].map(c => (
                <div key={c.mode} onClick={() => { setShowAdd(true); setAddMode(c.mode) }}
                  style={{ background: '#0e1117', border: '1px solid #21262d', padding: '20px 14px', textAlign: 'center', cursor: 'pointer', transition: 'all 0.15s' }}
                  onMouseEnter={e => { e.currentTarget.style.borderColor = '#30363d'; e.currentTarget.style.background = '#131720' }}
                  onMouseLeave={e => { e.currentTarget.style.borderColor = '#21262d'; e.currentTarget.style.background = '#0e1117' }}>
                  <div style={{ marginBottom: 8 }}>{c.icon}</div>
                  <div style={{ fontSize: 12, fontWeight: 500, color: '#c9d1d9', marginBottom: 4 }}>{c.label}</div>
                  <div style={{ fontSize: 10, color: '#484f58' }}>{c.desc}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}

      {/* ══════ ADD PANEL — shown on hub or detail ══════ */}
      {showAdd && (
        <div style={{ marginBottom: 16 }}>
          {rows.length === 0 && (
            <div style={{ fontSize: 15, fontWeight: 600, color: '#e6edf3', letterSpacing: '0.03em', marginBottom: 12 }}>PORTFOLIOS</div>
          )}
          <div style={{ background: '#0b0e11', border: '1px solid #21262d', padding: 16 }}>
            {/* Back to hub */}
            <div onClick={() => { setShowAdd(false); setAddMode('') }} style={{ fontSize: 10, color: '#388bfd', cursor: 'pointer', marginBottom: 12, display: 'inline-flex', alignItems: 'center', gap: 4 }}>
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" strokeWidth="1.5"><path d="M6 2L2 5l4 3"/></svg>
              Back
            </div>

            {/* Mode selector — if no mode chosen yet */}
            {addMode === '' && (
              <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 12 }}>
                {[
                  { mode: 'manual' as const, label: 'Create manually', icon: (
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="#8b949e" strokeWidth="1.3"><line x1="9" y1="3" x2="9" y2="15"/><line x1="3" y1="9" x2="15" y2="9"/></svg>
                  )},
                  { mode: 'watchlist' as const, label: 'From watchlist', icon: (
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="#8b949e" strokeWidth="1.3"><rect x="3" y="4" width="12" height="10" rx="1"/><line x1="5" y1="7" x2="13" y2="7"/><line x1="5" y1="11" x2="10" y2="11"/></svg>
                  )},
                  { mode: 'csv' as const, label: 'Upload CSV', icon: (
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="#8b949e" strokeWidth="1.3"><path d="M5 2h8l3 3v11H2V2h3z"/><line x1="5" y1="9" x2="13" y2="9"/><line x1="5" y1="12" x2="10" y2="12"/></svg>
                  )},
                ].map(c => (
                  <div key={c.mode} onClick={() => setAddMode(c.mode)}
                    style={{ background: '#0e1117', border: '1px solid #21262d', padding: '16px', textAlign: 'center', cursor: 'pointer', transition: 'all 0.15s' }}
                    onMouseEnter={e => { e.currentTarget.style.borderColor = '#30363d' }}
                    onMouseLeave={e => { e.currentTarget.style.borderColor = '#21262d' }}>
                    <div style={{ marginBottom: 6 }}>{c.icon}</div>
                    <div style={{ fontSize: 11, fontWeight: 500, color: '#c9d1d9' }}>{c.label}</div>
                  </div>
                ))}
              </div>
            )}

            {/* Manual form */}
            {addMode === 'manual' && (
              <div>
                <div style={{ fontSize: 12, color: '#c9d1d9', fontWeight: 500, marginBottom: 10 }}>Add position</div>
                <div style={{ display: 'flex', gap: 8, alignItems: 'flex-end', flexWrap: 'wrap' }}>
                  <div><div style={{ fontSize: 10, color: '#8b949e', marginBottom: 4 }}>Symbol</div><input value={sym} onChange={e => setSym(e.target.value)} placeholder="AAPL" style={{ ...inp, width: 90 }} /></div>
                  <div><div style={{ fontSize: 10, color: '#8b949e', marginBottom: 4 }}>Shares</div><input value={shares} onChange={e => setShares(e.target.value)} placeholder="100" type="number" style={{ ...inp, width: 80 }} /></div>
                  <div><div style={{ fontSize: 10, color: '#8b949e', marginBottom: 4 }}>Entry price</div><input value={entry} onChange={e => setEntry(e.target.value)} placeholder="150.00" type="number" step="0.01" style={{ ...inp, width: 100 }} /></div>
                  <div><div style={{ fontSize: 10, color: '#8b949e', marginBottom: 4 }}>Date</div><input value={date} onChange={e => setDate(e.target.value)} type="date" style={{ ...inp, width: 130 }} /></div>
                  <button onClick={add} style={{ padding: '6px 18px', fontSize: 12, background: '#388bfd', color: '#fff', border: 'none', borderRadius: 2, cursor: 'pointer', height: 32 }}>Add</button>
                </div>
              </div>
            )}

            {/* Watchlist picker */}
            {addMode === 'watchlist' && (
              <div>
                <div style={{ fontSize: 12, color: '#c9d1d9', fontWeight: 500, marginBottom: 10 }}>Select from watchlist</div>
                <div style={{ display: 'flex', flexWrap: 'wrap', gap: 6 }}>
                  {(watchlist ?? []).map((w: any) => {
                    const s = w.sym ?? w
                    const already = positions.some(p => p.symbol === s)
                    return (
                      <button key={s} onClick={() => { if (!already) addFromWL(s) }}
                        style={{ padding: '6px 14px', fontSize: 12, borderRadius: 2, cursor: already ? 'default' : 'pointer',
                          background: already ? '#3fb95015' : '#0e1117', border: `1px solid ${already ? '#3fb95033' : '#21262d'}`,
                          color: already ? '#3fb950' : '#c9d1d9', transition: 'all 0.15s' }}>
                        {already && '· '}{s}
                      </button>
                    )
                  })}
                </div>
              </div>
            )}

            {/* CSV upload */}
            {addMode === 'csv' && (
              <div>
                <div style={{ fontSize: 12, color: '#c9d1d9', fontWeight: 500, marginBottom: 10 }}>Upload CSV file</div>
                <div style={{ fontSize: 11, color: '#8b949e', marginBottom: 10, lineHeight: 1.5 }}>
                  Columns: <span style={{ color: '#c9d1d9' }}>Symbol, Shares, Price, Date</span>. Auto-detects headers.
                </div>
                <input ref={csvRef} type="file" accept=".csv,.tsv,.txt" onChange={handleCSV} style={{ fontSize: 12, color: '#8b949e' }} />
                <div style={{ marginTop: 10, padding: '8px 12px', background: '#0e1117', fontSize: 10, color: '#484f58', fontFamily: mono }}>
                  Symbol,Shares,Price,Date<br />AAPL,10,150.00,2024-01-15
                </div>
              </div>
            )}
          </div>
        </div>
      )}

      {/* ══════ PORTFOLIO DETAIL — when holdings exist ══════ */}
      {rows.length > 0 && (
        <>
          {/* Header + action bar */}
          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: 16 }}>
            <div style={{ fontSize: 16, fontWeight: 600, color: '#e6edf3', letterSpacing: '0.03em' }}>PORTFOLIO</div>
            {/* Action bar — TradingView style */}
            <div style={{ display: 'flex', gap: 6 }}>
              <button onClick={() => { setShowAdd(true); setAddMode('') }}
                style={{ padding: '7px 16px', fontSize: 11, background: '#161b22', color: '#c9d1d9', border: '1px solid #21262d', cursor: 'pointer', transition: 'all 0.15s', display: 'flex', alignItems: 'center', gap: 5 }}
                onMouseEnter={e => (e.currentTarget.style.borderColor = '#30363d')} onMouseLeave={e => (e.currentTarget.style.borderColor = '#21262d')}>
                Add transaction
                <svg width="8" height="8" viewBox="0 0 8 8" fill="none" stroke="currentColor" strokeWidth="1.5"><path d="M1 3l3 3 3-3"/></svg>
              </button>
              <button onClick={() => {
                const csv = 'Symbol,Shares,Price,Date\n' + positions.map(p => `${p.symbol},${p.shares},${p.entry},${p.date || ''}`).join('\n')
                const blob = new Blob([csv], { type: 'text/csv' })
                const url = URL.createObjectURL(blob)
                const a = document.createElement('a'); a.href = url; a.download = 'portfolio.csv'; a.click()
                URL.revokeObjectURL(url)
              }}
                style={{ padding: '7px 12px', fontSize: 11, background: 'transparent', color: '#484f58', border: '1px solid #21262d', cursor: 'pointer', transition: 'all 0.15s' }}
                onMouseEnter={e => (e.currentTarget.style.color = '#8b949e')} onMouseLeave={e => (e.currentTarget.style.color = '#484f58')}>
                Export
              </button>
            </div>
          </div>

          {/* Summary metrics — TradingView card style */}
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(4, 1fr)', gap: 12, marginBottom: 16 }}>
            {[
              { l: 'Portfolio value', v: fmtUsd(totalValue), sub: `${positions.length} positions`, c: '#c9d1d9' },
              { l: 'Unrealized gain', v: fmtUsd(totalPnl), sub: `Last day ${fmtUsd(dayPnl)}`, c: totalPnl >= 0 ? '#3fb950' : '#f85149' },
              { l: 'Total return', v: (totalPnlPct >= 0 ? '+' : '') + totalPnlPct.toFixed(2) + '%', sub: `Cost ${fmtUsd(totalCost)}`, c: totalPnlPct >= 0 ? '#3fb950' : '#f85149' },
              { l: 'Day change', v: fmtUsd(dayPnl), sub: dayPnl !== 0 ? `${(dayPnl / Math.max(totalValue - dayPnl, 1) * 100).toFixed(2)}% today` : '', c: dayPnl >= 0 ? '#3fb950' : '#f85149' },
            ].map(s => (
              <div key={s.l} style={{ border: '1px solid #21262d', padding: '12px 14px' }}>
                <div style={{ fontSize: 11, color: '#8b949e', marginBottom: 6 }}>{s.l}</div>
                <div style={{ fontSize: 20, fontWeight: 600, color: s.c, fontFamily: mono }}>{s.v}</div>
                {s.sub && <div style={{ fontSize: 10, color: '#484f58', marginTop: 4 }}>{s.sub}</div>}
              </div>
            ))}
          </div>

      {/* Portfolio analytics strip */}
      {positions.length > 0 && (
        <div style={{ display: 'flex', gap: 0, border: '1px solid #21262d', marginBottom: 12 }}>
          {[
            { l: 'BEST', v: rows.length > 0 ? rows.reduce((a, b) => a.pnlPct > b.pnlPct ? a : b).symbol : '—', n: rows.length > 0 ? '+' + rows.reduce((a, b) => a.pnlPct > b.pnlPct ? a : b).pnlPct.toFixed(1) + '%' : '', c: '#3fb950' },
            { l: 'WORST', v: rows.length > 0 ? rows.reduce((a, b) => a.pnlPct < b.pnlPct ? a : b).symbol : '—', n: rows.length > 0 ? rows.reduce((a, b) => a.pnlPct < b.pnlPct ? a : b).pnlPct.toFixed(1) + '%' : '', c: '#f85149' },
            { l: 'LARGEST', v: rows.length > 0 ? rows.reduce((a, b) => a.value > b.value ? a : b).symbol : '—', n: rows.length > 0 ? ((rows.reduce((a, b) => a.value > b.value ? a : b).value / totalValue) * 100).toFixed(0) + '% wt' : '', c: '#c9d1d9' },
            { l: 'POSITIONS', v: String(positions.length), n: `${sectors.length} sectors`, c: '#c9d1d9' },
          ].map(r => (
            <div key={r.l} style={{ flex: 1, padding: '6px 10px', borderRight: '1px solid #21262d' }}>
              <div style={{ fontSize: 8, color: '#484f58', letterSpacing: '0.06em' }}>{r.l}</div>
              <div style={{ fontSize: 12, fontWeight: 500, color: r.c, fontFamily: "'SF Mono', Menlo, Consolas, monospace" }}>{r.v} <span style={{ fontSize: 10, fontWeight: 400, color: '#484f58' }}>{r.n}</span></div>
            </div>
          ))}
        </div>
      )}

      {/* Portfolio change chart */}
      {positions.length > 0 && (
        <div style={{ marginBottom: 16 }}>
          <div style={{ fontSize: 14, fontWeight: 500, color: '#e6edf3', marginBottom: 10 }}>Portfolio change</div>
          <div style={{ display: 'flex', gap: 2, marginBottom: 8 }}>
            {[
              { key: '1mo', label: '1 month' },
              { key: '3mo', label: '3 months' },
              { key: '6mo', label: '6 months' },
              { key: '1y', label: '1 year' },
              { key: 'max', label: 'All time' },
            ].map(p => (
              <button key={p.key} onClick={() => setChartPeriod(p.key)}
                style={{
                  padding: '5px 14px', fontSize: 11, borderRadius: 2, cursor: 'pointer',
                  background: chartPeriod === p.key ? '#c9d1d9' : 'transparent',
                  color: chartPeriod === p.key ? '#0e1117' : '#8b949e',
                  border: `1px solid ${chartPeriod === p.key ? '#c9d1d9' : '#21262d'}`,
                  fontWeight: chartPeriod === p.key ? 600 : 400,
                }}>
                {p.label}
              </button>
            ))}
          </div>
          {chartLoading ? (
            <div style={{ height: 250, background: '#161b22', borderRadius: 2, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#8b949e', fontSize: 12 }}>Loading chart...</div>
          ) : chartData ? (
            <TvCandleChart data={chartData} height={250} showVolume={false} chartType="area" />
          ) : (
            <div style={{ height: 250, background: '#161b22', borderRadius: 2, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#8b949e', fontSize: 12 }}>No history available</div>
          )}
        </div>
      )}

      {/* ── Holdings ── */}
      {rows.length > 0 && (
        <div style={{ marginBottom: 16 }}>
          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: 6 }}>
            <span style={{ fontSize: 12, fontWeight: 500, color: '#e6edf3' }}>Holdings</span>
          </div>
          <table style={{ width: '100%', borderCollapse: 'collapse' }}>
            <thead><tr style={{ borderBottom: '1px solid #21262d' }}>
              {['Symbol','Shares','Entry','Current','Value','P/L',''].map(h=>
                <th key={h} style={{ padding: '4px 8px', textAlign: h==='Symbol'?'left':'right', color: '#484f58', fontSize: 10, fontWeight: 500, textTransform: 'uppercase', letterSpacing: '0.04em' }}>{h}</th>
              )}
            </tr></thead>
            <tbody>
              {rows.map(r => {
                const c = r.pnl >= 0 ? '#3fb950' : '#f85149'
                return (
                  <tr key={r.id} style={{ borderBottom: '1px solid #161b22', height: 32 }}>
                    <td style={{ padding: '4px 8px', fontSize: 12, fontWeight: 500, color: '#e6edf3', cursor: 'pointer' }} onClick={() => navigate(`/ticker/${r.symbol}`)}>{r.symbol}</td>
                    <td style={{ padding: '4px 8px', textAlign: 'right', fontSize: 11, fontFamily: mono, color: '#c9d1d9' }}>{r.shares}</td>
                    <td style={{ padding: '4px 8px', textAlign: 'right', fontSize: 11, fontFamily: mono, color: '#484f58' }}>{r.entry.toFixed(2)}</td>
                    <td style={{ padding: '4px 8px', textAlign: 'right', fontSize: 11, fontFamily: mono, color: '#c9d1d9' }}>{r.live.toFixed(2)}</td>
                    <td style={{ padding: '4px 8px', textAlign: 'right', fontSize: 11, fontFamily: mono, color: '#c9d1d9' }}>{fmtUsd(r.value)}</td>
                    <td style={{ padding: '4px 8px', textAlign: 'right', fontSize: 11, fontFamily: mono, color: c }}>{fmtUsd(r.pnl)} <span style={{fontSize:10}}>{r.pnlPct>=0?'+':''}{r.pnlPct.toFixed(1)}%</span></td>
                    <td style={{ padding: '4px 8px', textAlign: 'right' }}>
                      <button onClick={(e) => { e.stopPropagation(); remove(r.id) }}
                        style={{ fontSize: 10, color: '#f85149', background: 'none', border: '1px solid #30363d', padding: '1px 6px', cursor: 'pointer', opacity: 0.7 }}
                        onMouseEnter={e=>(e.currentTarget.style.opacity='1')} onMouseLeave={e=>(e.currentTarget.style.opacity='0.7')}>
                        Remove
                      </button>
                    </td>
                  </tr>
                )
              })}
            </tbody>
          </table>
        </div>
      )}

      {/* Daily gainers / losers */}
      {rows.length > 0 && (
        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 16, marginBottom: 16 }}>
          <div>
            <div style={{ fontSize: 12, fontWeight: 500, color: '#e6edf3', marginBottom: 10 }}>Daily gainers</div>
            {gainers.length === 0 ? <div style={{ fontSize: 11, color: '#8b949e' }}>No gainers today</div> : gainers.map(r => (
              <div key={r.id} onClick={() => navigate(`/ticker/${r.symbol}`)} style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 6, cursor: 'pointer' }}>
                <span style={{ fontSize: 11, color: '#c9d1d9', width: 50, fontWeight: 500, background: '#161b22', padding: '3px 8px', borderRadius: 2, textAlign: 'center' }}>{r.symbol}</span>
                <div style={{ flex: 1, height: 6, background: '#161b22', borderRadius: 2, overflow: 'hidden' }}>
                  <div style={{ height: '100%', width: `${(r.dayChg / maxAbsChg) * 100}%`, background: '#3fb950', borderRadius: 2 }} />
                </div>
                <span style={{ fontSize: 11, color: '#3fb950', fontFamily: "'SF Mono', Menlo, Consolas, monospace", fontWeight: 500, width: 55, textAlign: 'right' }}>+{r.dayChg.toFixed(2)}%</span>
              </div>
            ))}
          </div>
          <div>
            <div style={{ fontSize: 12, fontWeight: 500, color: '#e6edf3', marginBottom: 10 }}>Daily losers</div>
            {losers.length === 0 ? <div style={{ fontSize: 11, color: '#8b949e' }}>No losers today</div> : losers.map(r => (
              <div key={r.id} onClick={() => navigate(`/ticker/${r.symbol}`)} style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 6, cursor: 'pointer' }}>
                <span style={{ fontSize: 11, color: '#c9d1d9', width: 50, fontWeight: 500, background: '#161b22', padding: '3px 8px', borderRadius: 2, textAlign: 'center' }}>{r.symbol}</span>
                <div style={{ flex: 1, height: 6, background: '#161b22', borderRadius: 2, overflow: 'hidden' }}>
                  <div style={{ height: '100%', width: `${(Math.abs(r.dayChg) / maxAbsChg) * 100}%`, background: '#f85149', borderRadius: 2 }} />
                </div>
                <span style={{ fontSize: 11, color: '#f85149', fontFamily: "'SF Mono', Menlo, Consolas, monospace", fontWeight: 500, width: 55, textAlign: 'right' }}>{r.dayChg.toFixed(2)}%</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Portfolio distribution */}
      {rows.length > 0 && (
        <div style={{ marginBottom: 16 }}>
          <div style={{ fontSize: 12, fontWeight: 500, color: '#e6edf3', marginBottom: 10 }}>Portfolio distribution</div>
          <div style={{ display: 'flex', gap: 4, marginBottom: 14 }}>
            {(['sectors', 'assets'] as const).map(t => (
              <button key={t} onClick={() => setDistTab(t)}
                style={{ padding: '5px 14px', fontSize: 12, borderRadius: 2, border: '1px solid #21262d', cursor: 'pointer',
                  background: distTab === t ? '#c9d1d9' : 'transparent', color: distTab === t ? '#0e1117' : '#8b949e' }}>
                {t === 'sectors' ? 'Sectors' : 'Assets'}
              </button>
            ))}
          </div>
          <div style={{ display: 'grid', gridTemplateColumns: '180px 1fr', gap: 20, alignItems: 'start' }}>
            <DonutChart />
            <table style={{ width: '100%', borderCollapse: 'collapse' }}>
              <thead><tr style={{ borderBottom: '1px solid #21262d' }}>
                {distTab === 'sectors'
                  ? ['Sector', 'Holding value', 'Allocation', 'Unrealized gain'].map(h => <th key={h} style={{ padding: '5px 8px', textAlign: h === 'Sector' ? 'left' : 'right', color: '#484f58', fontSize: 10, fontWeight: 500, textTransform: 'uppercase', letterSpacing: '0.04em' }}>{h}</th>)
                  : ['Symbol', 'Shares', 'Cost', 'Current', 'Value', 'Weight', 'P/L', ''].map(h => <th key={h} style={{ padding: '5px 8px', textAlign: h === 'Symbol' ? 'left' : 'right', color: '#484f58', fontSize: 10, fontWeight: 500, textTransform: 'uppercase', letterSpacing: '0.04em' }}>{h}</th>)
                }
              </tr></thead>
              <tbody>
                {distTab === 'sectors' ? sectors.map(s => {
                  const sectorPnl = rows.filter(r => r.sector === s.name).reduce((sum, r) => sum + r.pnl, 0)
                  return (
                    <tr key={s.name} style={{ borderBottom: '1px solid #21262d' }}>
                      <td style={{ padding: '8px', fontSize: 12, color: '#c9d1d9', display: 'flex', alignItems: 'center', gap: 6 }}>
                        <span style={{ width: 8, height: 8, borderRadius: '50%', background: SCOL[s.name] ?? '#8b949e', display: 'inline-block' }} />{s.name}
                      </td>
                      <td style={{ padding: '8px', textAlign: 'right', color: '#c9d1d9', fontFamily: "'SF Mono', Menlo, Consolas, monospace", fontSize: 12 }}>{fmtUsd(s.val)}</td>
                      <td style={{ padding: '8px', textAlign: 'right', color: '#c9d1d9', fontFamily: "'SF Mono', Menlo, Consolas, monospace", fontSize: 12 }}>{s.pct.toFixed(1)}%</td>
                      <td style={{ padding: '8px', textAlign: 'right', color: sectorPnl >= 0 ? '#3fb950' : '#f85149', fontFamily: "'SF Mono', Menlo, Consolas, monospace", fontSize: 12 }}>{fmtUsd(sectorPnl)}</td>
                    </tr>
                  )
                }) : rows.map(r => {
                  const col = r.pnl >= 0 ? '#3fb950' : '#f85149'
                  const wt = totalValue > 0 ? ((r.value / totalValue) * 100).toFixed(1) : '0'
                  return (
                    <tr key={r.id} style={{ borderBottom: '1px solid #21262d', cursor: 'pointer', height: 34 }}
                      onClick={() => navigate(`/ticker/${r.symbol}`)}
                      onMouseEnter={e => (e.currentTarget.style.background = '#1c2128')} onMouseLeave={e => (e.currentTarget.style.background = 'transparent')}>
                      <td style={{ padding: '5px 8px', color: '#e6edf3', fontWeight: 500, fontSize: 12 }}>{r.symbol}</td>
                      <td style={{ padding: '5px 8px', textAlign: 'right', color: '#c9d1d9', fontFamily: mono, fontSize: 11 }}>{r.shares}</td>
                      <td style={{ padding: '5px 8px', textAlign: 'right', color: '#484f58', fontFamily: mono, fontSize: 11 }}>{r.entry.toFixed(2)}</td>
                      <td style={{ padding: '5px 8px', textAlign: 'right', color: '#c9d1d9', fontFamily: mono, fontSize: 11 }}>{r.live.toFixed(2)}</td>
                      <td style={{ padding: '5px 8px', textAlign: 'right', color: '#c9d1d9', fontFamily: mono, fontSize: 11 }}>{fmtUsd(r.value)}</td>
                      <td style={{ padding: '5px 8px', textAlign: 'right', color: '#484f58', fontFamily: mono, fontSize: 10 }}>{wt}%</td>
                      <td style={{ padding: '5px 8px', textAlign: 'right', fontFamily: mono, fontSize: 11 }}>
                        <span style={{ color: col }}>{fmtUsd(r.pnl)}</span>
                        <span style={{ color: col, fontSize: 10, marginLeft: 4 }}>{r.pnlPct >= 0 ? '+' : ''}{r.pnlPct.toFixed(1)}%</span>
                      </td>
                      <td style={{ padding: '5px 8px', textAlign: 'right' }}>
                        <span onClick={e => { e.stopPropagation(); if (window.confirm(`Remove ${r.symbol}?`)) remove(r.id) }} style={{ color: '#30363d', cursor: 'pointer', fontSize: 11 }}
                          onMouseEnter={e => (e.currentTarget.style.color = '#f85149')} onMouseLeave={e => (e.currentTarget.style.color = '#30363d')}>×</span>
                      </td>
                    </tr>
                  )
                })}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* Position Sizing Calculator */}
      <div style={{ background: '#0b0e11', border: '1px solid #21262d', padding: 16, marginTop: 12 }}>
        <div style={{ fontSize: 12, fontWeight: 500, color: '#e6edf3', marginBottom: 12 }}>Position Sizing Calculator</div>
        <PositionSizer portfolioValue={totalValue || 100000} />
      </div>
        </>
      )}

      {/* Empty state handled by hub above */}
    </div>
  )
}
